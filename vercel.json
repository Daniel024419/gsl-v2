{
  "version": 2,
  "framework": null,

  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },

  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/storage/app/public/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/([^/]+\\.(?:png|jpg|jpeg|gif|svg|webp|ico|css|js|map|woff|woff2|ttf|eot|pdf))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],

  "env": {
    "APP_NAME": "GSL Website",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://gsl-one.vercel.app",

    "APP_KEY": "base64:DA+epACypI9WGOzF4dRaaDgtrIyX6YIYy6Vhx5TXcKM=",

    "ASSET_URL": "https://gsl-one.vercel.app",

    "DB_CONNECTION": "sqlite",

    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",

    "VIEW_COMPILED_PATH": "/tmp",

    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr"
  }
}